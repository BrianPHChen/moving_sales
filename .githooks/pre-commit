#!/bin/sh
# Auto-bumps the "last updated" timestamp and cache-busting ?v= query
# strings whenever data.js or index.html are part of the commit.
set -e

if ! git diff --cached --name-only | grep -qE '^(data\.js|index\.html)$'; then
  exit 0
fi

TS_ISO=$(date +"%Y-%m-%dT%H:%M:%S%z" | sed -E 's/([0-9]{2})([0-9]{2})$/\1:\2/')
TS_VERSION=$(date +"%Y%m%d%H%M%S")

sed -i '' -E "s/window\.MOVING_SALE_LAST_UPDATED = \"[^\"]*\";/window.MOVING_SALE_LAST_UPDATED = \"$TS_ISO\";/" data.js
sed -i '' -E "s/\?v=[0-9]+/?v=$TS_VERSION/g" index.html

git add data.js index.html

echo "pre-commit: bumped last-updated timestamp and cache-busting version to $TS_VERSION"
